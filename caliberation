# ---------------------------
# ROI DETECTION
# ---------------------------

def check_holes_roi(frame):
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    matched = 0

    h, w = gray.shape

    for idx, (x, y) in enumerate(EXPECTED_POSITIONS):

        x1 = max(0, x - ROI_SIZE)
        y1 = max(0, y - ROI_SIZE)
        x2 = min(w, x + ROI_SIZE)
        y2 = min(h, y + ROI_SIZE)

        roi_full = gray[y1:y2, x1:x2]

        if roi_full.size == 0:
            continue

        # Center ROI
        h_roi, w_roi = roi_full.shape

        cx1 = int(w_roi * 0.3)
        cy1 = int(h_roi * 0.3)
        cx2 = int(w_roi * 0.7)
        cy2 = int(h_roi * 0.7)

        roi = roi_full[cy1:cy2, cx1:cx2]

        dark_pixels = np.sum(roi < DARK_PIXEL_THRESHOLD)
        total_pixels = roi.size
        dark_ratio = dark_pixels / total_pixels

        if dark_ratio > DARK_RATIO_THRESHOLD:
            matched += 1
            color = (0, 255, 255)
            label = "OK"
        else:
            color = (0, 0, 255)
            label = "MISS"

        cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)

        cv2.putText(frame, f"{idx+1}:{label}",
                    (x1, y2 + 15),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    0.5,
                    color,
                    1)

    return matched, frame


# ---------------------------
# TEST IMAGE
# ---------------------------

def test_on_image(path):
    frame = cv2.imread(path)
    matched, output = check_holes_roi(frame)

    cv2.putText(output, f"Matched: {matched}/6",
                (20, 40),
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                (0,255,0) if matched==6 else (0,0,255),
                2)

    cv2.imshow("Result", output)
    cv2.waitKey(0)
    cv2.destroyAllWindows()


