import cv2
import numpy as np
import time
import os
from tkinter import Tk, filedialog
from picamera2 import Picamera2

# ---------------------------
# CONFIGURATION
# ---------------------------

EXPECTED_HOLES = 6

ROI_SIZE = 22
DARK_PIXEL_THRESHOLD = 100
DARK_RATIO_THRESHOLD = 0.05

SAVE_DIR = "captured_frames"
os.makedirs(SAVE_DIR, exist_ok=True)

# ---------------------------
# GLOBAL STORAGE
# ---------------------------

EXPECTED_POSITIONS = []
clicked_points = []

# ---------------------------
# MOUSE CALLBACK
# ---------------------------

def mouse_callback(event, x, y, flags, param):
    global clicked_points

    if event == cv2.EVENT_LBUTTONDOWN:
        if len(clicked_points) < 6:
            clicked_points.append((x, y))
            print(f"Point {len(clicked_points)}:", (x, y))


# ---------------------------
# CALIBRATION (IMAGE)
# ---------------------------

def calibrate_from_image(image_path):
    global clicked_points
    clicked_points = []

    frame = cv2.imread(image_path)
    clone = frame.copy()

    cv2.namedWindow("Calibration")
    cv2.setMouseCallback("Calibration", mouse_callback)

    print("\n👉 Click 6 holes (Top L → Bottom R)\n")

    while True:
        temp = clone.copy()

        for i, (x, y) in enumerate(clicked_points):
            cv2.circle(temp, (x, y), 6, (0, 255, 255), -1)
            cv2.putText(temp, str(i+1), (x+5, y-5),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 1)

        cv2.imshow("Calibration", temp)

        if cv2.waitKey(1) == 27:
            break

    cv2.destroyAllWindows()

    print("\n✅ COPY THIS:\n")
    print("EXPECTED_POSITIONS = [")
    for p in clicked_points:
        print(f"    {p},")
    print("]")


