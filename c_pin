if __name__ == "__main__":
    # Always try to load calibration at startup
    load_calibration()

    print("\n=== PCB Pin Inspection System v2 ===")
    print("1 → Calibrate (REQUIRED first time — select clamped + empty images)")
    print("2 → Test on Image (Normal)")
    print("3 → Test on Image (Calibration/Debug Mode)")
    print("4 → Run Camera (Normal)")
    print("5 → Run Camera (Debug Mode)")

    choice = input("\nEnter choice (1-5): ").strip()

    if choice == "1":
        run_calibration()

    elif choice in ("2", "3"):
        path = pick_image()
        if path:
            test_on_image(path, calibration_mode=(choice == "3"))
        else:
            print("No image selected.")

    elif choice in ("4", "5"):
        run_camera(calibration_mode=(choice == "5"))

    else:
        print("Invalid choice")
