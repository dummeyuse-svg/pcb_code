def test_on_image(image_path, calibration_mode=False):
    frame = cv2.imread(image_path)
    if frame is None:
        print("❌ Could not load image:", image_path)
        return

    original_frame = frame.copy()
    pin_count, output, results = check_pins_roi(frame, calibration_mode)

    if pin_count == EXPECTED_HOLES:
        status, color = "OK", (0, 255, 0)
    else:
        status, color = "ERROR", (0, 0, 255)
        missing = [str(r[0]) for r in results if not r[2]]
        log_error(f"[IMAGE] Pins: {pin_count}/6. Missing: {', '.join(missing)}")

    output = draw_status(output, pin_count, status, color)
    save_frame(original_frame, output, status, pin_count)
    cv2.imshow("PCB Inspection — Image Test", output)
    cv2.waitKey(0)
    cv2.destroyAllWindows()


def pick_image(multi=False):
    Tk().withdraw()
    if multi:
        return filedialog.askopenfilenames(
            title="Select PCB Images",
            filetypes=[("Images", "*.jpg *.jpeg *.png *.bmp")]
        )
    return filedialog.askopenfilename(
        title="Select PCB Image",
        filetypes=[("Images", "*.jpg *.jpeg *.png *.bmp")]
    )


